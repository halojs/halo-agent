{
  "name": "@halo-ai/desktop",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/halojs/halo-agent",
  "bugs": {
    "url": "https://github.com/halojs/halo-agent/issues"
  },
  "license": "MIT",
  "author": "Allen Luo <luoyi@mouji.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halojs/halo-agent.git",
    "directory": "apps/desktop"
  },
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run --parallel dev:bundle dev:electron",
    "dev:bundle": "tsdown --watch",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "tsdown",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@halo-ai/contracts": "workspace:*",
    "effect": "catalog:prod",
    "electron": "catalog:desktop",
    "electron-updater": "catalog:desktop"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:dev",
    "@effect/vitest": "catalog:testing",
    "@types/node": "catalog:types",
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:build",
    "vitest": "catalog:testing"
  },
  "engines": {
    "bun": "^1.3.12",
    "node": "^24.14.1"
  },
  "packageManager": "bun@1.3.14",
  "productName": "Halo (Alpha)"
}
