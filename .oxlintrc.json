{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    ".docs",
    ".plans",
    ".github",
    "dist",
    "node_modules",
    "repos",
    "*.tsbuildinfo"
  ],
  "plugins": ["eslint", "oxc", "react", "unicorn", "typescript"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react-in-jsx-scope": "off",
    "no-array-index-key": "off",
    "eslint/no-shadow": "off",
    "eslint/no-await-in-loop": "off"
  }
}
