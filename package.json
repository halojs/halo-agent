{
  "name": "@halo-ai/halo-agent",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/halojs/halo-agent",
  "bugs": {
    "url": "https://github.com/halojs/halo-agent/issues"
  },
  "license": "MIT",
  "author": "Allen Luo <luoyi@mouji.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halojs/halo-agent.git"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalogs": {
      "web": {
        "@base-ui/react": "^1.4.1",
        "@tanstack/react-query": "^5.100.10",
        "@tanstack/react-router": "^1.169.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "motion": "^12.38.0",
        "react-dom": "^19.2.6",
        "react": "^19.2.6",
        "shadcn": "^4.7.0",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0"
      },
      "assets": {
        "@fontsource-variable/dm-sans": "^5.2.8",
        "@fontsource-variable/geist": "^5.2.8",
        "lucide-react": "^1.16.0"
      },
      "build": {
        "lint-staged": "^17.0.4",
        "oxfmt": "^0.49.0",
        "oxlint": "^1.64.0",
        "simple-git-hooks": "^2.13.1",
        "tsdown": "^0.22.0",
        "turbo": "^2.9.14",
        "typescript": "^6.0.3",
        "vite": "^8.0.13"
      },
      "dev": {
        "@babel/core": "^7.29.0",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/router-plugin": "^1.167.35",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-react-compiler": "^1.0.0"
      },
      "testing": {
        "@testing-library/react": "^16.3.2",
        "jsdom": "^29.1.1",
        "vitest": "^4.1.6"
      },
      "types": {
        "@types/babel__core": "^7.20.5",
        "@types/bun": "1.3.11",
        "@types/node": "^25.8.0",
        "@types/react-dom": "^19.2.3",
        "@types/react": "^19.2.14"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev:web": "turbo run dev --filter=@halo-ai/web",
    "dev:server": "turbo run dev --filter=@halo-ai/server",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "turbo run test",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "lint-staged": "catalog:build",
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "simple-git-hooks": "catalog:build",
    "turbo": "catalog:build",
    "typescript": "catalog:build",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*.{tsx,ts}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.css": "oxfmt"
  },
  "engines": {
    "bun": "^1.3.12",
    "node": "^24.14.1"
  },
  "packageManager": "bun@1.3.14"
}
