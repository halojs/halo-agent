{
  "name": "@halo-ai/halo-agent",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/halojs/halo-agent",
  "bugs": {
    "url": "https://github.com/halojs/halo-agent/issues"
  },
  "license": "MIT",
  "author": "Allen Luo <luoyi@mouji.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halojs/halo-agent.git"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalogs": {
      "desktop": {
        "electron": "^42.2.0",
        "electron-updater": "^6.8.3"
      },
      "web": {
        "@base-ui/react": "^1.5.0",
        "@tanstack/react-query": "^5.100.14",
        "@tanstack/react-router": "^1.170.8",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "motion": "^12.40.0",
        "react-dom": "^19.2.6",
        "react": "^19.2.6",
        "shadcn": "^4.8.0",
        "tailwind-merge": "^3.6.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0"
      },
      "assets": {
        "@fontsource-variable/dm-sans": "^5.2.8",
        "@fontsource-variable/geist": "^5.2.9",
        "lucide-react": "^1.16.0"
      },
      "build": {
        "lint-staged": "^17.0.5",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "simple-git-hooks": "^2.13.1",
        "tsdown": "^0.22.0",
        "turbo": "^2.9.14",
        "typescript": "^6.0.3",
        "vite": "^8.0.14"
      },
      "prod": {
        "effect": "^3.21.2"
      },
      "dev": {
        "@babel/core": "^7.29.0",
        "@effect/experimental": "^0.60.0",
        "@effect/language-service": "^0.86.2",
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/router-plugin": "^1.168.11",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-react-compiler": "^1.0.0"
      },
      "testing": {
        "@effect/vitest": "^0.29.0",
        "@testing-library/react": "^16.3.2",
        "@vitest/coverage-v8": "^4.1.7",
        "jsdom": "^29.1.1",
        "vitest": "^4.1.7"
      },
      "types": {
        "@types/babel__core": "^7.20.5",
        "@types/bun": "1.3.11",
        "@types/node": "^25.9.1",
        "@types/react-dom": "^19.2.3",
        "@types/react": "^19.2.15"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --ui=tui --filter=@halo-ai/web --filter=@halo-ai/server --parallel",
    "dev:web": "turbo run dev --filter=@halo-ai/web",
    "dev:server": "turbo run dev --filter=@halo-ai/server",
    "lint": "oxlint --report-unused-disable-directives",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "turbo run test",
    "prepare": "simple-git-hooks && effect-language-service patch",
    "clean": "rm -rf bun.lock node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist packages/*/coverage .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:dev",
    "@types/node": "catalog:types",
    "lint-staged": "catalog:build",
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "simple-git-hooks": "catalog:build",
    "turbo": "catalog:build",
    "typescript": "catalog:build",
    "vitest": "catalog:testing"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*.{tsx,ts}": [
      "oxfmt",
      "oxlint --fix"
    ],
    "*.css": "oxfmt"
  },
  "engines": {
    "bun": "^1.3.12",
    "node": "^24.14.1"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "electron"
  ]
}
