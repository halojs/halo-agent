{
  "name": "@halo-ai/contracts",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/halojs/halo-agent",
  "bugs": {
    "url": "https://github.com/halojs/halo-agent/issues"
  },
  "license": "MIT",
  "author": "Allen Luo <luoyi@mouji.net>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halojs/halo-agent.git",
    "directory": "packages/contracts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsdown src/index.ts --format esm,cjs --dts --watch --clean",
    "build": "tsdown src/index.ts --format esm,cjs --dts --clean",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "catalog:prod"
  },
  "devDependencies": {
    "@types/bun": "catalog:types",
    "@types/node": "catalog:types",
    "oxfmt": "catalog:build",
    "oxlint": "catalog:build",
    "tsdown": "catalog:build",
    "typescript": "catalog:build"
  }
}
